<!DOCTYPE html>
<html>
<head>
    <title>Edit Clothing Item</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-4">

<div class="container mt-2 py-4 mb-4 bg-dark rounded-3 text-white">
    <div class="p-4">
        <h2 class="fw-bolder display-5">Edit clothing item</h2>
        <p class="lead">Make changes to your donated clothing item</p>
    </div>
</div>

<form action="/items/<%= item.item_id %>" method="POST" enctype="multipart/form-data">

    <% if (isCharityAdmin) { %>
        <div class="alert alert-info">
            Charity Admin: Charity cannot be changed
        </div>
    <% } %>

    <div class="mb-3">
        <label class="form-label">Title</label>
        <input class="form-control" name="title" value="<%= item.title %>" <%= canFullEdit ? '' : 'disabled' %>>
    </div>

    <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea class="form-control" name="description" <%= canFullEdit ? '' : 'disabled' %>><%= item.description %> </textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Category</label>
        <select class="form-select" name="category" <%= canFullEdit ? '' : 'disabled' %>>
            <% ['Men','Women','Children','Unisex'].forEach(cat => { %>
                <option value="<%= cat %>" <%= item.category === cat ? 'selected' : '' %>>
                    <%= cat %>
                </option>
            <% }) %>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Size</label>
        <select class="form-select" name="size" <%= canFullEdit ? '' : 'disabled' %>>
            <% ['XS','S','M','L','XL','XXL'].forEach(size => { %>
                <option value="<%= size %>" <%= item.size === size ? 'selected' : '' %>>
                    <%= size %>
                </option>
            <% }) %>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Condition</label>
        <select class="form-select" name="condition_desc" <%= canFullEdit ? '' : 'disabled' %>>
            <% ['New','Good','Worn'].forEach(cond => { %>
                <option value="<%= cond %>" <%= item.condition_desc === cond ? 'selected' : '' %>>
                    <%= cond %>
                </option>
            <% }) %>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Assign to Charity Centre</label>
            <select name="charity_id" class="form-select"<%= (isCharityAdmin || !(donorCanFullyEdit || donorCanChangeCharity)) ? 'disabled' : '' %>>
                <option value="">No charity assigned</option>
                <% charity_centres.forEach(charity => { %>
                    <option value="<%= charity.charity_id %>"
                        <%= item.charity_id === charity.charity_id ? 'selected' : '' %>>
                        <%= charity.charity_name %>
                    </option>
                <% }) %>
             </select>
    </div>

    <div class="mb-3">

        <!-- Show existing images -->
        <% if (item.images && item.images.length > 0) { %>
            <div class="mb-3">
            <label>Current Images:</label>

            <div class="d-flex flex-wrap">

                <% item.images.forEach((img, index) => { %>

                    <div class="position-relative me-2 mb-2">

                        <!-- Image -->
                        <img src="/uploads/<%= img %>" 
                            style="width:100px; height:100px; object-fit:cover;"
                            class="rounded shadow-sm"
                            data-bs-toggle="modal"
                            data-bs-target="#imageCarouselModal"
                            data-index="<%= index %>"
                            onclick="openCarousel(this)">

                        <!--  Delete Button -->
                        <% if (canFullEdit) { %>
                            <button type="button"
                                    onclick="deleteImage('<%= item.item_id %>', '<%= img %>')"
                                    class="btn btn-danger btn-sm position-absolute"
                                    style="top:5px; right:5px; width:22px; height:22px; padding:0; border-radius:50%; z-index:10;">
                                ✕
                            </button>
                        <% } %>

                    </div>

                <% }) %>

                <% } else { %>

            <!-- PLACEHOLDER -->
            <img src="/uploads/placeholder.jpg"
                 style="width:100px; height:100px; object-fit:cover;"
                 class="rounded shadow-sm">

              <% } %>

            </div>
        </div>

        <!-- Upload new image -->
        <input type="file" name="images" multiple class="form-control" onchange="previewImage(event)" <%= canFullEdit ? '' : 'disabled' %>>

        <!-- Preview new image -->
        <div id="preview-container" class="d-flex flex-wrap mt-2"></div>
    </div>


    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a href="/items/my" class="btn btn-secondary">Cancel</a>

</form>

<div class="modal fade" id="imageCarouselModal" tabindex="-1">
    <div class="modal-header border-0">
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
    </div>
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content bg-dark">

            <div class="modal-body">

                <div id="carouselImages" class="carousel slide" data-bs-ride="false">

                <div class="carousel-inner">

                    <% if (item.images && item.images.length > 0) { %>
                        <% item.images.forEach((img, index) => { %>
                    <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                        <img src="/uploads/<%= img %>" class="d-block w-100 rounded">
                    </div>
                     <% }) %>
                    <% } %>
                </div>

                <!-- Controls -->
                <button class="carousel-control-prev" type="button" data-bs-target="#carouselImages" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>

                <button class="carousel-control-next" type="button" data-bs-target="#carouselImages" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>

                </div>

            </div>

            </div>
        </div>
     </div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>

function previewImage(event) {
    const files = event.target.files;
    const container = document.getElementById('preview-container');

    container.innerHTML = ''; // clear previous previews

    if (!files.length) return;

    Array.from(files).forEach(file => {

        if (!file.type.startsWith('image/')) return;

        const img = document.createElement('img');

        img.src = URL.createObjectURL(file);
        img.className = "me-2 mb-2 rounded shadow-sm";
        img.style.width = "100px";
        img.style.height = "100px";
        img.style.objectFit = "cover";

        container.appendChild(img);
    });
}

function openCarousel(element) {
    const index = element.getAttribute('data-index');

    const carousel = document.querySelector('#carouselImages');
    const carouselInstance = bootstrap.Carousel.getOrCreateInstance(carousel);

    carouselInstance.to(parseInt(index));
}

function deleteImage(itemId, filename) {

    if (!confirm("Delete this image?")) return;

    fetch(`/items/${itemId}/images/delete`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ filename })
    })
    .then(() => location.reload())
    .catch(err => console.error(err));
}
</script>
</body>
</html>
