<!DOCTYPE html>
<html>
<head>
    <title>Incoming Donations</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="container mt-4">

<h2 class="mb-4">Items not received</h2>
<p class="text-muted">Items allocated and awaiting arrival</p>

<% if (items.length === 0) { %>
    <p>No incoming items.</p>
<% } %>

<div class="row">

<% items.forEach(item => { %>

<div class="col-md-4 mb-4">
    <div class="card h-100">

        <div class="card-body">

            <h5><%= item.title %></h5>
            <p><%= item.description %></p>

            <p class="text-muted">
                Category: <%= item.category %><br>
                Size: <%= item.size %><br>
                Condition: <%= item.condition_desc %><br>
                Donor: <%= item.donor %>
            </p>

            <span class="badge bg-warning">Awaiting Arrival</span>

            <form action="/admin/items/<%= item.item_id %>/received"
                  method="POST"
                  class="mt-3">

                <button class="btn btn-success btn-sm">
                    Mark as Received
                </button>

            </form>

        </div>

    </div>
</div>

<% }) %>

</div>

<a href="/admin/charitydashboard" class="btn btn-outline-dark mt-3">Back</a>

</body>
</html>