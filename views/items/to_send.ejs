<!DOCTYPE html>
<html>
<head>
    <title>Items to Send</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-4">

<div class="container mt-2 py-4 mb-4 bg-dark rounded-3 text-white">
    <div class="p-4">
        <h2 class="fw-bolder display-5">Items to Send to Charity</h2>
        <p class="lead">These items have been approved and must be delivered to the assigned charity</p>
    </div>
</div>

<% if (items.length === 0) { %>
    <div class="alert alert-info">
        No items currently need to be sent.
    </div>
<% } %>

<div class="row">
    <% items.forEach(item => { %>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">

                <!-- IMAGE -->
                <% if (item.images.length > 0) { %>
                    <img src="/uploads/<%= item.images[0] %>" 
                         class="card-img-top"
                         style="height:200px; object-fit:cover;">
                <% } else { %>
                    <img src="/uploads/placeholder.jpg" 
                         class="card-img-top"
                         style="height:200px; object-fit:cover;">
                <% } %>

                <div class="card-body d-flex flex-column">

                    <h5 class="card-title"><%= item.title %></h5>

                    <p class="card-text">
                        <%= item.description || 'No description provided.' %>
                    </p>

                    <!--<p class="text-muted mb-2">
                        <strong>Category:</strong> <%= item.category %><br>
                        <strong>Size:</strong> <%= item.size %><br>
                        <strong>Condition:</strong> <%= item.condition_desc %><br>
                        <strong>Charity:</strong> <%= item.charity_name %>
                    </p>-->

                    <!-- STATUS BADGE -->
                    <span class="badge bg-warning mb-2">To be sent to <%= item.charity_name %></span>

                    <div class="mt-2 p-2 bg-light rounded">

                        <strong>Deliver To:</strong><br>

                        <%= item.charity_name %><br>

                        <small>
                            <%= item.charity_address %><br>
                            <%= item.charity_postcode %>
                        </small>

                        <% if (item.charity_phone) { %>
                            <div class="mt-1">
                                📞 <%= item.charity_phone %>
                            </div>
                        <% } %>

                        <% if (item.charity_email) { %>
                            <div>
                                ✉️ <%= item.charity_email %>
                            </div>
                        <% } %>

                    </div>

                </div>
            </div>
        </div>

    <% }) %>
</div>

<a href="/homepage" class="btn btn-outline-dark">Back</a>

</body>
</html>