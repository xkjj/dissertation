<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body class="container mt-4">

<div class="container mt-2 mb-4 bg-dark rounded-3 text-white position-relative">
    <div class="p-5 bg-dark text-white rounded-3 text-center">
        <div class="position-absolute top-0 start-0 p-3 d-flex flex-column align-items-start gap-1">
            <span class="badge bg-light text-dark px-3 py-2 fs-6">
                Logged in as: <%= user.username %> (<%= user.role %>)
            </span>
            <a href="/logout" class="btn btn-outline-light mt-2">Logout</a>
        </div>

        <h1 class="display-5 fw-bold">Admin Dashboard</h1>
        <p class="lead">Manage user accounts</p>

        <a href="/homepage" class="btn btn-light mt-2 me-2">Homepage</a>
        <a href="/admin/charity-centres" class="btn btn-outline-light mt-2">View Charity Centres</a>
    </div>
</div>

<div class="container mt-4">

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-dark">
                <div class="card-body">
                    <h3 class="fw-bold"><%= users.length %></h3>
                    <p class="text-muted mb-0">Total Users</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-primary">
                <div class="card-body">
                    <h3 class="fw-bold text-primary">
                        <%= users.filter(u => u.role === 'donor').length %>
                    </h3>
                    <p class="text-muted mb-0">Donors</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-success">
                <div class="card-body">
                    <h3 class="fw-bold text-success">
                        <%= users.filter(u => u.role === 'recipient').length %>
                    </h3>
                    <p class="text-muted mb-0">Recipients</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-warning">
                <div class="card-body">
                    <h3 class="fw-bold text-warning">
                        <%= users.filter(u => u.is_active === 0).length %>
                    </h3>
                    <p class="text-muted mb-0">Disabled Accounts</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4 p-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label small fw-semibold">Search Users</label>
                <input type="text" id="searchInput" class="form-control"
                       placeholder="Search by name or username...">
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Filter by Role</label>
                <select id="roleFilter" class="form-select">
                    <option value="">All Roles</option>
                    <option value="donor">Donor</option>
                    <option value="recipient">Recipient</option>
                    <option value="charity_admin">Charity Admin</option>
                    <option value="sys_admin">System Admin</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Filter by Status</label>
                <select id="statusFilter" class="form-select">
                    <option value="">All</option>
                    <option value="1">Active</option>
                    <option value="0">Disabled</option>
                </select>
            </div>
            <div class="col-md-1">
                <button onclick="clearFilters()" class="btn btn-outline-secondary w-100">
                    Clear
                </button>
            </div>
        </div>
    </div>

    <p class="text-muted small mb-2" id="userCount">
        Showing <%= users.length %> user<%= users.length !== 1 ? 's' : '' %>
    </p>

    <div class="card shadow-sm">
        <table class="table table-bordered align-middle mb-0" id="usersTable">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Username</th>
                    <th>Role</th>
                    <th>Phone</th>
                    <th>Postcode</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user => { %>
                    <tr class="user-row"
                        data-name="<%= (user.firstname + ' ' + user.surname + ' ' + user.username).toLowerCase() %>"
                        data-role="<%= user.role %>"
                        data-status="<%= user.is_active %>">

                        <td class="text-muted small"><%= user.user_id %></td>

                        <td>
                            <div class="fw-semibold"><%= user.firstname %> <%= user.surname %></div>
                            <small class="text-muted"><%= user.username %></small>
                        </td>

                        <td class="text-muted"><%= user.username %></td>

                        <td>
                            <% if (user.role === 'sys_admin') { %>
                                <span class="badge bg-dark px-3 py-2">System Admin</span>
                            <% } else { %>
                                <form action="/admin/update-role" method="POST" class="d-flex gap-2 align-items-center">
                                    <input type="hidden" name="user_id" value="<%= user.user_id %>">
                                    <select name="role" class="form-select form-select-sm">
                                        <option value="donor" <%= user.role === 'donor' ? 'selected' : '' %>>Donor</option>
                                        <option value="recipient" <%= user.role === 'recipient' ? 'selected' : '' %>>Recipient</option>
                                        <option value="charity_admin" <%= user.role === 'charity_admin' ? 'selected' : '' %>>Charity Admin</option>
                                    </select>
                                    <button class="btn btn-sm btn-dark">Save</button>
                                </form>
                            <% } %>
                        </td>

                        <td><%= user.phone %></td>
                        <td><%= user.postcode %></td>

                        <td>
                            <span class="badge <%= user.is_active ? 'bg-success' : 'bg-danger' %>">
                                <%= user.is_active ? 'Active' : 'Disabled' %>
                            </span>
                        </td>

                        <td>
                            <% if (user.role === 'sys_admin') { %>
                                <span class="badge bg-secondary">N/A</span>
                            <% } else { %>
                                <form action="/admin/toggle-user" method="POST">
                                    <input type="hidden" name="user_id" value="<%= user.user_id %>">
                                    <button class="btn btn-sm <%= user.is_active ? 'btn-warning' : 'btn-success' %>">
                                        <%= user.is_active ? 'Disable' : 'Enable' %>
                                    </button>
                                </form>
                            <% } %>
                        </td>

                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
// filter the users table based on the current values of the search, role and status inputs
function filterUsers() {
    const search = document.getElementById('searchInput').value.toLowerCase();
    const role = document.getElementById('roleFilter').value;
    const status = document.getElementById('statusFilter').value;

    const rows = document.querySelectorAll('.user-row');
    let visible = 0;

    rows.forEach(row => {
        const nameMatch = !search || row.dataset.name.includes(search); // check whether row's name/username data attribute contains search - if no search is entered, all rows pass
        const roleMatch = !role || row.dataset.role === role; // check whether row's role data matches role filter - if no role is selected, all rows pass
        const statusMatch = !status || row.dataset.status === status; // check whether row's active status matches selected status filter - if no status is selected, all rows pass

        const show = nameMatch && roleMatch && statusMatch; // only show row if it passes all 3 filter checks simultaneously
        row.style.display = show ? '' : 'none';
        if (show) visible++;
    });

    // update count
    document.getElementById('userCount').textContent =
        `Showing ${visible} user${visible !== 1 ? 's' : ''}`;
}

// reset all filter inputs to their default empty state and re-run the filter
function clearFilters() {
    document.getElementById('searchInput').value = '';
    document.getElementById('roleFilter').value = '';
    document.getElementById('statusFilter').value = '';
    filterUsers();
}

document.getElementById('searchInput').addEventListener('input', filterUsers); // re-filter the table in real time as the user types in the search box
document.getElementById('roleFilter').addEventListener('change', filterUsers); // re-filter the table immediately when the role dropdown selection changes
document.getElementById('statusFilter').addEventListener('change', filterUsers); // re-filter the table immediately when the status dropdown selection changes
</script>
</body>
</html>