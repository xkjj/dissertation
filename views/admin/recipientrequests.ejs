<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Recipient Requests</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body class="container mt-4">

<!-- Hero Banner -->
<div class="container mt-2 mb-4 bg-dark rounded-3 text-white position-relative">
    <div class="p-5 bg-dark text-white rounded-3 text-center">
        <div class="position-absolute top-0 start-0 p-3 d-flex flex-column align-items-start gap-1">
            <span class="badge bg-light text-dark px-3 py-2 fs-6">
                Logged in as: <%= user.username %> (<%= user.role %>)
            </span>
            <a href="/logout" class="btn btn-outline-light mt-2">Logout</a>
        </div>

        <h1 class="display-5 fw-bold">Recipient Requests</h1>
        <p class="lead">Review and manage item requests from recipients</p>

        <a href="/homepage" class="btn btn-light mt-2 me-2">Homepage</a>
    </div>
</div>

<div class="container-fluid px-4">
    <div class="row">

        <!-- Sidebar -->
        <div class="col-md-2 sidebar pt-3 pe-3">
            <p class="text-muted text-uppercase fw-semibold small mb-2 ms-2">Navigation</p>
            <nav class="nav flex-column">
                <a href="/admin/charitydashboard" class="nav-link">Items</a>
                <a href="/admin/recipientrequests" class="nav-link active">
                    Requests
                    <span class="badge bg-secondary ms-1"><%= requests.length %></span>
                </a>
                <a href="/admin/incoming-items" class="nav-link">Items to Receive</a>
                <a href="/admin/charity-items" class="nav-link">
                    View Donations
                    <span class="badge <%= pendingDonations > 0 ? 'bg-danger' : 'bg-secondary' %>">
                        <%= pendingDonations %>
                    </span>
                </a>
            </nav>
        </div>

        <!-- Main Content -->
        <div class="col-md-10 pt-3">

            <!-- Filter tabs -->
            <ul class="nav nav-tabs mb-4" id="requestTabs">
                <li class="nav-item">
                    <button class="nav-link active" onclick="filterRequests('all')">
                        All
                        <span class="badge bg-secondary ms-1"><%= requests.length %></span>
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" onclick="filterRequests('pending')">
                        Pending
                        <span class="badge bg-warning text-dark ms-1">
                            <%= requests.filter(r => r.status === 'pending').length %>
                        </span>
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" onclick="filterRequests('approved')">
                        Approved
                        <span class="badge bg-success ms-1">
                            <%= requests.filter(r => r.status === 'approved').length %>
                        </span>
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" onclick="filterRequests('rejected')">
                        Rejected
                        <span class="badge bg-danger ms-1">
                            <%= requests.filter(r => r.status === 'rejected').length %>
                        </span>
                    </button>
                </li>
            </ul>

            <p class="text-muted small mb-3" id="requestCount">
                Showing <%= requests.length %> request<%= requests.length !== 1 ? 's' : '' %>
            </p>

            <% if (requests.length === 0) { %>
                <div class="text-center py-5 text-muted">
                    <p class="fs-5">No requests submitted yet.</p>
                </div>
            <% } else { %>
                <div class="row g-3 mb-5" id="requestsGrid">
                    <% requests.forEach(request => { %>
                        <div class="col-xl-3 col-lg-4 col-md-6 request-card" data-status="<%= request.status %>">
                            <div class="card h-100 shadow-sm">

                                <img
                                    src="/uploads/<%= request.image || 'placeholder.jpg' %>"
                                    class="card-img-top"
                                >

                                <div class="card-body d-flex flex-column">
                                    <h6 class="fw-bold mb-1"><%= request.title %></h6>

                                    <p class="small mb-2">
                                        Requested by: <strong><%= request.requester %></strong><br>
                                        <span class="text-muted">
                                            <%= new Date(request.requested_at).toLocaleDateString('en-GB', {
                                                day: '2-digit', month: 'short', year: 'numeric',
                                                hour: '2-digit', minute: '2-digit'
                                            }) %>
                                        </span>
                                    </p>

                                    <%
                                        const badgeClass =
                                            request.status === 'approved' ? 'bg-success' :
                                            request.status === 'rejected' ? 'bg-danger' :
                                            'bg-warning text-dark';
                                    %>
                                    <span class="badge <%= badgeClass %> mb-3 align-self-start">
                                        <%= request.status.charAt(0).toUpperCase() + request.status.slice(1) %>
                                    </span>

                                    <% if (request.status === 'pending') { %>
                                        <div class="mt-auto d-flex gap-2">
                                            <form action="/admin/charitydashboard/<%= request.request_id %>/approve" method="POST" class="flex-fill">
                                                <button class="btn btn-success btn-sm w-100">Approve</button>
                                            </form>
                                            <form action="/admin/charitydashboard/<%= request.request_id %>/reject" method="POST" class="flex-fill">
                                                <button class="btn btn-danger btn-sm w-100">Reject</button>
                                            </form>
                                        </div>
                                    <% } %>
                                </div>

                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
function filterRequests(status) {
    document.querySelectorAll('#requestTabs .nav-link').forEach(btn => {
        btn.classList.remove('active');
        if (btn.getAttribute('onclick') === `filterRequests('${status}')`) {
            btn.classList.add('active');
        }
    });

    let visible = 0;
    document.querySelectorAll('.request-card').forEach(card => {
        const match = status === 'all' || card.dataset.status === status;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
    });

    document.getElementById('requestCount').textContent =
        `Showing ${visible} request${visible !== 1 ? 's' : ''}`;
}
</script>

</body>
</html>