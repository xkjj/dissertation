<!DOCTYPE html>
<html>
<head>
    <title>My Clothing Listings</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body class="container mt-4">

<div class="container mt-2 mb-4 bg-dark rounded-3 text-white position-relative">
    <div class="p-5 bg-dark text-white rounded-3 text-center">
      <div class="position-absolute top-0 start-0 p-3 d-flex flex-column align-items-start gap-1">
          <span class="badge bg-light text-dark px-3 py-2 fs-6">
             Logged in as: <%= user.username %> (<%= user.role %>)
          </span>
          <a href="/logout" class="btn btn-outline-light mt-2">Logout</a>
      </div>

        <h1 class="display-5 fw-bold">My Clothing Listings</h1>
        <p class="lead">View and make changes to your listed items</p>

        <a href="/homepage" class="btn btn-light mt-2 me-2">Back</a>
        <a href="/items/impact" class="btn btn-success mt-2 me-2">My Impact</a>

    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card text-center shadow-sm border-dark">
            <div class="card-body">
                <h3 class="fw-bold"><%= items.length %></h3>
                <p class="text-muted mb-0">Total Listings</p>
                <a href="/items/my" class="btn btn-secondary btn-sm mt-2">View</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center shadow-sm border-primary">
            <div class="card-body">
                <h3 class="fw-bold text-primary"><%= items.filter(i => i.status === 'allocated').length %></h3>
                <p class="text-muted mb-0">Ready to Send</p>
                <a href="/items/to-send" class="btn btn-primary btn-sm mt-2">View</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center shadow-sm border-danger">
            <div class="card-body">
                <h3 class="fw-bold text-danger"><%= items.filter(i => !i.charity_id).length %></h3>
                <p class="text-danger mb-0">Unassigned</p>
                <a href="/items/unassigned" class="btn btn-outline-danger btn-sm mt-2">View</a>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <ul class="nav nav-tabs" id="statusTabs">
        <li class="nav-item">
            <button class="nav-link active" onclick="filterMyItems('all')">
                All
                <span class="badge bg-secondary ms-1"><%= items.length %></span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="filterMyItems('approved')">
                Approved
                <span class="badge bg-success ms-1">
                    <%= items.filter(i => i.status === 'approved').length %>
                </span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="filterMyItems('unassigned')">
                Unassigned
                <span class="badge bg-danger ms-1">
                    <%= items.filter(i => i.status === 'unassigned').length %>
                </span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="filterMyItems('assigned')">
                Assigned
                <span class="badge bg-warning text-dark ms-1">
                    <%= items.filter(i => i.status === 'assigned').length %>
                </span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="filterMyItems('allocated')">
                Ready to Send
                <span class="badge bg-primary ms-1">
                    <%= items.filter(i => i.status === 'allocated').length %>
                </span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" onclick="filterMyItems('delivered')">
                Delivered
                <span class="badge bg-dark ms-1">
                    <%= items.filter(i => i.status === 'delivered').length %>
                </span>
            </button>
        </li>
    </ul>
            <a href="/items/new" class="btn btn-dark mt-2 me-2">+ Add New Item</a>
</div>

<div class="container mt-4">
    <p class="text-muted mb-3">
    Showing <%= items.length %> item<%= items.length !== 1 ? 's' : '' %>
    </p>
    
    <div class="row g-3">

        <% if (items.length === 0) { %>
            <p>You have not listed any clothing items yet.</p>
        <% } %>

        <% items.forEach(item => { %>
            <div class="col-xl-3 col-lg-3 col-md-4 col-sm-6 item-card" data-status="<%= item.status %>">

                <div class="card h-100 shadow-sm">
                    <img 
                        src="/uploads/<%= item.images?.[0] || 'placeholder.jpg' %>"
                        class="card-img-top"
                        >

                    <div class="card-body d-flex flex-column">

                        <h6 class="card-title mb-1"><%= item.title %></h6>

                        <p class="card-text small mb-2">
                            <%= item.description %>
                        </p>

                        <p class="text-muted small mb-2">
                            <strong>Category:</strong> <%= item.category %><br>
                            <strong>Size:</strong> <%= item.size || 'N/A' %><br>
                            <strong>Charity:</strong> <%= item.charity_name || 'Not assigned' %><br>
                            <%
                                const statusBadge = {
                                    approved: 'bg-success',
                                    assigned: 'bg-warning text-dark',
                                    delivered: 'bg-dark',
                                    allocated: 'bg-primary',
                                    unassigned: 'bg-secondary'
                                }[item.status] || 'bg-danger';
                            %>
                            <span class="badge <%= statusBadge %> mb-2"><%= item.status %></span>
                        </p>

                        <!-- Push buttons to bottom -->
                        <div class="mt-auto">

                            <% if (donorCanDelete(item.status)) { %>
                                <div class="mt-auto d-flex gap-2">

                                    <a href="/items/<%= item.item_id %>/edit" class="btn btn-sm btn-secondary flex-fill">
                                        Edit
                                    </a>

                                    <form action="/items/<%= item.item_id %>/delete" method="POST" class="flex-fill">
                                        <button class="btn btn-sm btn-outline-danger w-100"
                                                onclick="return confirm('Delete this item?');">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

    <button id="backToTopBtn" class="btn btn-dark shadow"
        style="position: fixed; bottom: 50px; right: 50px; display: none; z-index: 1000;
               padding: 12px 22px; font-size: 20px; border-radius: 50px;">
        ↑
    </button>

<script>
const backToTopBtn = document.getElementById("backToTopBtn");

// Show button when scrolling
window.addEventListener("scroll", () => {
    if (window.scrollY > 300) {
        backToTopBtn.style.display = "block";
    } else {
        backToTopBtn.style.display = "none";
    }
});

// Smooth scroll to top
backToTopBtn.addEventListener("click", () => {
    window.scrollTo({
        top: 0,
        behavior: "smooth"
    });
});

function filterMyItems(status) {
    // Update active tab
    document.querySelectorAll('#statusTabs .nav-link').forEach(btn => {
        btn.classList.remove('active');
        if (btn.getAttribute('onclick') === `filterMyItems('${status}')`) {
            btn.classList.add('active');
        }
    });

    // Show/hide cards
    let visible = 0;
    document.querySelectorAll('.item-card').forEach(card => {
        const match = status === 'all' || card.dataset.status === status;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
    });

    // Update count text
    document.querySelector('.text-muted.mb-3').textContent =
        `Showing ${visible} item${visible !== 1 ? 's' : ''}`;
}
</script>

<style>

#backToTopBtn:hover {
    transform: translateY(-2px);
}
</style>

</body>
</html>
