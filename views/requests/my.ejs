<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>My Requests</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>

<body>

<div class="container mt-2 py-4 mb-4 bg-dark rounded-3 text-white">
    <div class="p-4">
        <h2 class="fw-bolder display-5">My Clothing Requests</h2>
        <p class="lead">Track the status of items you have requested</p>
    </div>
</div>

<div class="container">

    <% if (requests.length === 0) { %>
        <div class="alert alert-info">
            You have not requested any clothing items yet.
        </div>
    <% } else { %>

        <table class="table table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Item</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <% requests.forEach(request => { %>
                    <tr>
                        <td>
                            <%= request.title %>
                        </td>
                        <td>

                        <% if (request.item_status === 'sent') { %>

                            <span class="badge bg-primary">Sent</span>

                            <div class="mt-2">

                                <form action="/requests/<%= request.request_id %>/delivered"
                                    method="POST"
                                    class="d-inline">

                                    <button class="btn btn-sm btn-primary">
                                        Mark as Delivered
                                    </button>

                                </form>

                                <form action="/requests/<%= request.request_id %>/never-arrived"
                                    method="POST"
                                    class="d-inline ms-2">

                                    <button class="btn btn-sm btn-danger">
                                        Never Arrived
                                    </button>

                                </form>

                            </div>

                        <% } else if (request.item_status === 'delivered') { %>

                            <span class="badge bg-primary">Delivered</span>

                        <% } else if (request.item_status === 'never_arrived') { %>

                            <span class="badge bg-danger">Never Arrived</span>

                        <% } else if (request.status === 'approved') { %>

                            <span class="badge bg-success">Approved</span>

                        <% } else if (request.status === 'pending') { %>

                            <span class="badge bg-warning text-dark">Pending</span>

                        <% } else { %>

                            <span class="badge bg-danger">Rejected</span>

                        <% } %>

                    </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

    <% } %>

    <a href="/homepage" class="btn btn-outline-dark mt-3">
        Back to Home
    </a>

</div>

</body>
</html>
