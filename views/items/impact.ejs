<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>My Impact</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body class="container mt-4">

<!-- Hero Header -->
<div class="container mt-2 mb-4 bg-dark rounded-3 text-white position-relative">
    <div class="p-5 bg-dark text-white rounded-3 text-center">
        <div class="position-absolute top-0 start-0 p-3 d-flex flex-column align-items-start gap-1">
            <span class="badge bg-light text-dark px-3 py-2 fs-6">
                Logged in as: <%= user.username %> (<%= user.role %>)
            </span>
            <a href="/logout" class="btn btn-outline-light mt-2">Logout</a>
        </div>

        <h1 class="display-5 fw-bold">My Impact</h1>
        <p class="lead">See how your donations have made a difference</p>

        <a href="/items/my" class="btn btn-light mt-2">Back to My Listings</a>
    </div>
</div>

<div class="container mt-4">

    <!-- Summary Cards -->
    <div class="row g-3 mb-5">

        <div class="col-md-4">
            <div class="card text-center shadow-sm border-success h-100">
                <div class="card-body py-4">
                    <h2 class="fw-bold text-success"><%= totalDelivered %></h2>
                    <p class="text-muted mb-0">Items Successfully Delivered</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-center shadow-sm border-primary h-100">
                <div class="card-body py-4">
                    <h2 class="fw-bold text-primary"><%= charitiesCount %></h2>
                    <p class="text-muted mb-0">Charities Supported</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-center shadow-sm border-dark h-100">
                <div class="card-body py-4">
                    <h2 class="fw-bold"><%= Object.keys(categories).length %></h2>
                    <p class="text-muted mb-0">Categories Donated</p>
                </div>
            </div>
        </div>

    </div>

    <!-- Category Breakdown -->
    <% if (Object.keys(categories).length > 0) { %>
    <div class="card shadow-sm mb-5 p-4">
        <h5 class="fw-bold mb-3">Donations by Category</h5>
        <% Object.entries(categories).forEach(([cat, count]) => { %>
            <div class="mb-2">
                <div class="d-flex justify-content-between mb-1">
                    <span class="small fw-semibold"><%= cat %></span>
                    <span class="small text-muted"><%= count %> item<%= count !== 1 ? 's' : '' %></span>
                </div>
                <div class="progress" style="height: 8px;">
                    <div class="progress-bar bg-dark"
                         style="width: <%= Math.round((count / totalDelivered) * 100) %>%">
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
    <% } %>

    <!-- Delivered Items -->
    <h4 class="mb-3">Delivered Items</h4>

    <% if (items.length === 0) { %>
        <div class="alert alert-info">
            None of your donations have been delivered yet. 
            Keep donating — you're making a difference!
        </div>
    <% } else { %>

    <div class="row g-3">
        <% items.forEach(item => { %>
            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="card h-100 shadow-sm">

                    <img src="/uploads/<%= item.image || 'placeholder.jpg' %>"
                         class="card-img-top card-img-cover">

                    <div class="card-body d-flex flex-column">

                        <h6 class="fw-bold mb-1"><%= item.title %></h6>
                        <p class="text-muted small mb-2"><%= item.description %></p>

                        <p class="small mb-2">
                            <strong>Category:</strong> <%= item.category %><br>
                            <strong>Size:</strong> <%= item.size %><br>
                            <strong>Condition:</strong> <%= item.condition_desc %><br>
                            <strong>Charity:</strong> <%= item.charity_name || 'N/A' %>
                        </p>

                        <div class="mt-auto">
                            <span class="badge bg-success w-100 py-2">
                                ✓ Successfully Delivered
                            </span>
                            <% if (item.delivered_at) { %>
                                <small class="text-muted d-block text-center mt-1">
                                    <%= new Date(item.delivered_at).toLocaleDateString('en-GB', {
                                        day: '2-digit', month: 'short', year: 'numeric'
                                    }) %>
                                </small>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>

    <% } %>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>