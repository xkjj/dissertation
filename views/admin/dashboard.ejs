<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-4">

<div class="container mt-2 mb-4 bg-dark rounded-3 text-white position-relative">
    <div class="p-5 bg-dark text-white rounded-3 text-center">
      <div class="position-absolute top-0 start-0 p-3 d-flex flex-column align-items-start gap-1">
          <span class="badge bg-light text-dark px-3 py-2 fs-6">
             Logged in as: <%= user.username %> (<%= user.role %>)
          </span>
          <a href="/logout" class="btn btn-outline-light mt-2">Logout</a>
      </div>

        <h1 class="display-5 fw-bold">Admin Dashboard</h1>
        <p class="lead">Manage user accounts</p>

        <a href="/items/my" class="btn btn-light mt-2 me-2">Back</a>
    </div>
</div>

<div class="container mt-4">

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Username</th>
                <th>Role</th>
                <th>Phone</th>
                <th>Postcode</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach(user => { %>
                <tr>
                    <td><%= user.user_id %></td>
                    <td><%= user.firstname %> <%= user.surname %></td>
                    <td><%= user.username %></td>
                    <td>
                        <% if (user.role === 'sys_admin') { %>
                            <span class="badge bg-dark">System Admin</span>
                        <% } else { %>
                            <form action="/admin/update-role" method="POST" class="d-flex gap-2">
                                <input type="hidden" name="user_id" value="<%= user.user_id %>">

                                <select name="role" class="form-select form-select-sm">
                                <option value="donor" <%= user.role === 'donor' ? 'selected' : '' %>>Donor</option>
                                <option value="recipient" <%= user.role === 'recipient' ? 'selected' : '' %>>Recipient</option>
                                <option value="charity_admin" <%= user.role === 'charity_admin' ? 'selected' : '' %>>Charity Admin</option>
                                </select>

                                <button class="btn btn-sm btn-primary">Save</button>
                            </form>
                        <% } %>
                    </td>
                    <td><%= user.phone %></td>
                    <td><%= user.postcode %></td>
                    <td>
                        <span class="badge <%= user.is_active ? 'bg-success' : 'bg-danger' %>">
                            <%= user.is_active ? 'Active' : 'Disabled' %>
                        </span>
                        </td>
                        <td>
                            <% if (user.role === 'sys_admin') { %>
                            <span class="badge bg-dark">N/A</span>
                             <% } else { %>
                            <form action="/admin/toggle-user" method="POST">
                                <input type="hidden" name="user_id" value="<%= user.user_id %>">

                                <% if (Number(user.is_active) === 1) { %>
                                <button class="btn btn-sm btn-warning">Disable</button>
                                <% } else { %>
                                <button class="btn btn-sm btn-success">Enable</button>
                                    <% } %>
                             <% } %>
                            </form>
                        </td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <a href="/logout" class="btn btn-dark mt-3">Logout</a>
    <a href="/homepage" class="btn btn-dark mt-3">Homepage</a>
    <a href="/admin/charity-centres" class="btn btn-dark mt-3">View charity centres</a>
</div>

</body>
</html>
