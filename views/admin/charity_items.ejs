<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Charity Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="container mt-4">

<div class="container mt-2 mb-4 bg-dark rounded-3 text-white position-relative">
    <div class="p-5 bg-dark text-white rounded-3 text-center">
      <div class="position-absolute top-0 start-0 p-3 d-flex flex-column align-items-start gap-1">
          <span class="badge bg-light text-dark px-3 py-2 fs-6">
             Logged in as: <%= user.username %> (<%= user.role %>)
          </span>
          <a href="/logout" class="btn btn-outline-light mt-2">Logout</a>
      </div>

        <h1 class="display-5 fw-bold">Charity Dashboard</h1>
        <p class="lead">Manage items and requests for your charity</p>

        <a href="/homepage" class="btn btn-light mt-2 me-2">Homepage</a>

    </div>
</div>

<div class="container-fluid px-4">
    <div class="row">

        <!-- Sidebar -->
        <div class="col-md-2 sidebar pt-3 pe-3">
            <p class="text-muted text-uppercase fw-semibold small mb-2 ms-2">Navigation</p>
            <nav class="nav flex-column">
                <a href="/admin/charitydashboard" class="nav-link">Items</a>
                <a href="/admin/recipientrequests" class="nav-link">Requests</a>
                <a href="/admin/incoming-items" class="nav-link">Items to Receive</a>
                <a href="/admin/charity-items" class="nav-link active">
                    View Donations
                    <span class="badge bg-secondary"><%= items.length %></span>
                </a>
            </nav>
        </div>

        <!-- Main Content -->
        <div class="col-md-10 pt-3">

            <h4 class="mb-4">Incoming Donations</h4>

            <% if (items.length === 0) { %>
                <p class="text-muted">No donation requests at this time.</p>
            <% } else { %>

            <div class="row">
                <% items.forEach(item => { %>
                    <div class="col-md-4 mb-4">
                        <div class="card h-100 shadow-sm">
                             <!-- Image -->
                                <img src="<%= item.image ? '/uploads/' + item.image : '/uploads/placeholder.jpg' %>"
                                    class="card-img-top">
                            <div class="card-body">

                                <h5 class="fw-bold"><%= item.title %></h5>
                                <p class="text-muted small"><%= item.description %></p>

                                <p class="small mb-2">
                                    <strong>Category:</strong> <%= item.category %><br>
                                    <strong>Size:</strong> <%= item.size %><br>
                                    <strong>Condition:</strong> <%= item.condition_desc %><br>
                                    Donor: <strong><%= item.donor %></strong>
                                </p>

                                <div class="d-flex gap-2 mt-3">
                                    <form action="/admin/charity-items/<%= item.item_id %>/approve"
                                          method="POST" class="flex-fill">
                                        <button class="btn btn-success btn-sm w-100">Accept</button>
                                    </form>
                                    <form action="/admin/charity-items/<%= item.item_id %>/reject"
                                          method="POST" class="flex-fill">
                                        <button class="btn btn-danger btn-sm w-100">Reject</button>
                                    </form>
                                </div>

                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <% } %>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
