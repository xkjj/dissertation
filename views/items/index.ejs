<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Available Clothing</title>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    window.currentUserId = <%- JSON.stringify(user ? user.user_id : null) %>;  
    window.currentUserRole = <%- JSON.stringify(user ? user.role : null) %>;   </script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="container mt-4">


<div class="container mt-2 pb-4 mb-4 bg-dark rounded-3 text-white position-relative">
    <div class="p-5 bg-dark text-white rounded-3 text-center">
         <div class="position-absolute top-0 start-0 p-3 d-flex flex-column align-items-start gap-1">
          <span class="badge bg-light text-dark px-3 py-2 fs-6">
             Logged in as: <%= user.username %> (<%= user.role %>)
          </span>
          <a href="/logout" class="btn btn-outline-light mt-2">Logout</a>
           <a href="/homepage" class="btn btn-outline-light mt-3">Back</a>
      </div>
        <h2 class="fw-bolder display-5">Available Clothing</h2>
        <p class="lead">Browse donated clothing items</p>
    </div>
    
    <form onsubmit="return false;" class="mb-2">

<div class="d-flex justify-content-center mb-3 px-3">
    <div class="input-group" style="max-width: 500px;">
        <input 
            type="text" 
            name="search" 
            class="form-control" 
            placeholder="Search clothing items..."
            value="<%= search || '' %>"
        >
        <button type="button" class="btn btn-dark" onclick="fetchItems()">Search</button>
    </div>
</div>

      <div class="mt-4 px-3">

        <div class="row g-3 align-items-end">

            <div class="col-lg-3 col-md-6">
                <label class="form-label small text-white">Category</label>
                <select name="category" class="form-select">
                    <option value="">All</option>
                    <% ['Men','Women','Children','Unisex'].forEach(cat => { %>
                        <option value="<%= cat %>" <%= category === cat ? 'selected' : '' %>>
                            <%= cat %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <div class="col-lg-3 col-md-6">
                <label class="form-label small text-white">Size</label>
                <select name="size" class="form-select">
                    <option value="">All</option>
                    <% ['XS','S','M','L','XL','XXL'].forEach(s => { %>
                        <option value="<%= s %>" <%= size === s ? 'selected' : '' %>>
                            <%= s %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <div class="col-lg-3 col-md-6">
                <label class="form-label small text-white">Condition</label>
                <select name="condition" class="form-select">
                    <option value="">All</option>
                    <% ['New','Good','Worn'].forEach(c => { %>
                        <option value="<%= c %>" <%= condition === c ? 'selected' : '' %>>
                            <%= c %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <div class="col-lg-2 col-md-6">
                <label class="form-label small text-white">Sort</label>
                <select name="sort" class="form-select">
                    <option value="">Newest</option>
                    <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Oldest</option>
                    <option value="az" <%= sort === 'az' ? 'selected' : '' %>>A–Z</option>
                </select>
            </div>

            <div class="col-lg-1 d-flex align-items-end">
                <a href="/items" class="btn btn-outline-light w-100">
                    Clear
                </a>
            </div>

        </div>

</div>
</form>

</div>

</form>
</div>

<div class="container mt-4">
    <div class="row">

        <div class="col-12">

            <% if (items.length === 0) { %>
                <p>No clothing items are currently available.</p>
            <% } %>

            <div id="itemsContainer" class="row g-3">

                <% items.forEach(item => { %>
                    <div class="col-xl-3 col-lg-3 col-md-4 col-sm-6">

                        <a href="/items/<%= item.item_id %>" class="text-decoration-none text-dark">
                            <div class="card h-100 shadow-sm w-100">

                                <img 
                                    src="/uploads/<%= item.images.length > 0 ? item.images[0] : 'placeholder.jpg' %>" 
                                    class="card-img-top"
                                >

                                <div class="card-body d-flex flex-column">

                                    <h6 class="card-title mb-1"><%= item.title %></h6>

                                    <p class="card-text small mb-2">
                                        <%= item.description || 'No description provided.' %>
                                    </p>

                                    <p class="text-muted small mb-2">
                                        <strong>Category:</strong> <%= item.category %><br>
                                        <strong>Size:</strong> <%= item.size || 'N/A' %><br>
                                        <strong>Condition:</strong> <%= item.condition_desc %><br>
                                        <strong>Charity:</strong> <%= item.charity_name || 'Not assigned' %>
                                    </p>

                                    <div class="mt-auto">
                                        <% if (user) { %>

                                            <% if (item.status !== 'approved') { %>
                                                <button class="btn btn-sm btn-secondary w-100" disabled>Unavailable</button>

                                            <% } else if (user.user_id === item.owner_id) { %>
                                                <button class="btn btn-sm btn-info w-100" disabled>Your Item</button>

                                            <% } else if (item.request_status === 'approved') { %>
                                                <button class="btn btn-sm btn-outline-success w-100" disabled>Approved</button>

                                            <% } else if (item.request_status === 'pending') { %>
                                                <button class="btn btn-sm btn-outline-warning w-100" disabled>Pending</button>

                                            <% } else if (item.request_status === 'rejected') { %>
                                                <button class="btn btn-sm btn-outline-danger w-100" disabled>Rejected</button>

                                            <% } else { %>
                                                <form action="/requests" method="POST">
                                                    <input type="hidden" name="item_id" value="<%= item.item_id %>">
                                                    <button class="btn btn-sm btn-dark w-100">Request Item</button>
                                                </form>
                                            <% } %>

                                        <% } %>
                                    </div>

                                    <% if (user && (user.role === 'charity_admin' || user.role === 'sys_admin')) { %>
                                        <small class="text-muted mt-2">
                                            Donated by: <%= item.username %>
                                        </small>
                                    <% } %>

                                </div>
                            </div>
                        </a>

                    </div>
                <% }) %>

            </div>

            <nav class="mt-4">
                <ul id="pagination" class="pagination justify-content-center">

                    <% if (currentPage > 1) { %>
                        <li class="page-item">
                            <a class="page-link" href="?page=<%= currentPage - 1 %>&search=<%= search %>&category=<%= category %>&size=<%= size %>&condition=<%= condition %>&sort=<%= sort %>">
                                Previous
                            </a>
                        </li>
                    <% } %>

                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                            <a class="page-link" href="?page=<%= i %>&search=<%= search %>&category=<%= category %>&size=<%= size %>&condition=<%= condition %>&sort=<%= sort %>">
                                <%= i %>
                            </a>
                        </li>
                    <% } %>

                    <% if (currentPage < totalPages) { %>
                        <li class="page-item">
                            <a class="page-link" href="?page=<%= currentPage + 1 %>&search=<%= search %>&category=<%= category %>&size=<%= size %>&condition=<%= condition %>&sort=<%= sort %>">
                                Next
                            </a>
                        </li>
                    <% } %>

                </ul>
            </nav>

        </div>
    </div>
</div>

<script>
let debounceTimer; // debounce search and filter input events
let currentPage = 1; // track current page number

// collect current values of all search, filter and sorts
// return as object to be used a query params
function getFilters() {
    return {
        search: document.querySelector('input[name="search"]').value,
        category: document.querySelector('select[name="category"]').value,
        size: document.querySelector('select[name="size"]').value,
        condition: document.querySelector('select[name="condition"]').value,
        sort: document.querySelector('select[name="sort"]').value,
        page: currentPage
    };
}

// fetch items from the API using the current filter values
function fetchItems() {

    const params = new URLSearchParams(getFilters()); // updates the browser URL to reflect the active filters without a full page reload
    history.replaceState(null, '', '/items?' + params.toString()); // update the browser URL with the current filters so the page is bookmarkable

    // call api endpoint from app.js and re-render items grid and pagination on response
    fetch('/api/items?' + params.toString())
        .then(res => res.json())
        .then(data => {
            renderItems(data.items);
            renderPagination(data.totalPages, data.currentPage);
        });
}

// render items grid with results returned from API
function renderItems(items) {

    // only show donor username if logged in as charity or system admin
    const showDonor = window.currentUserRole === 'charity_admin' ||
                      window.currentUserRole === 'sys_admin';
    const container = document.getElementById('itemsContainer');

    if (items.length === 0) {
        container.innerHTML = '<p>No items found.</p>';
        return;
    }

    container.innerHTML = items.map(item => {

        // use first image available, otherwise use placeholder
        const img = item.images.length > 0 ? item.images[0] : 'placeholder.jpg';

        // determine correct button to display based on item status
        let button = '';

        if (item.status !== 'approved') {
            button = `<button class="btn btn-sm btn-secondary w-100" disabled>Unavailable</button>`; // item unavailable for request

        } else if (item.owner_id && item.owner_id === window.currentUserId) {
            button = `<button class="btn btn-sm btn-info w-100" disabled>Your Item</button>`; // logged-in user is the donor of this item

        } else if (item.request_status === 'approved') {
            button = `<button class="btn btn-sm btn-outline-success w-100" disabled>Approved</button>`; // request has been approved

        } else if (item.request_status === 'pending') {
            button = `<button class="btn btn-sm btn-outline-warning w-100" disabled>Pending</button>`; // request submitted and is pending

        } else if (item.request_status === 'rejected') {
            button = `<button class="btn btn-sm btn-outline-danger w-100" disabled>Rejected</button>`; // request rejected

        // no existing request - show request button     
        } else {
            button = `
                <form action="/requests" method="POST">
                    <input type="hidden" name="item_id" value="${item.item_id}">
                    <button class="btn btn-sm btn-dark w-100">Request Item</button>
                </form>
            `;
        }

        // return HTML for a single item card
        return `
        <div class="col-xl-3 col-lg-3 col-md-4 col-sm-6">
            <a href="/items/${item.item_id}" class="text-decoration-none text-dark">
                <div class="card h-100 shadow-sm w-100">

                    <img src="/uploads/${img}" 
                         class="card-img-top">

                    <div class="card-body d-flex flex-column">

                        <h6 class="card-title mb-1">${item.title}</h6>

                        <p class="card-text small mb-2">
                            ${item.description || 'No description provided.'}
                        </p>

                        <p class="text-muted small mb-2">
                            <strong>Category:</strong> ${item.category}<br>
                            <strong>Size:</strong> ${item.size || 'N/A'}<br>
                            <strong>Condition:</strong> ${item.condition_desc}<br>
                            <strong>Charity:</strong> ${item.charity_name || 'Not assigned'}
                        </p>

                        ${button}

                        ${showDonor ? `<small class="text-muted mt-2">Donated by: ${item.username || 'Unknown'}</small>` : ''}

                    </div>
                </div>
            </a>
        </div>
        `;
    }).join('');
}

// render pagination controls based on total pages and current page
function renderPagination(totalPages, page) {

    const pagination = document.getElementById('pagination');

    if (!pagination || totalPages <= 1) { // hide pagination if there is only one page or no pagination element exists
        pagination.innerHTML = '';
        return;
    }

    let html = '';

    // previous button - disabled if on first page
    html += `
    <li class="page-item ${page === 1 ? 'disabled' : ''}">
        <a class="page-link" href="#" onclick="goToPage(${page - 1}); return false;">
            Previous
        </a>
    </li>`;

    // page number buttons - highlighted on current page
    for (let i = 1; i <= totalPages; i++) {
        html += `
        <li class="page-item ${i === page ? 'active' : ''}">
            <a class="page-link" href="#" onclick="goToPage(${i}); return false;">
                ${i}
            </a>
        </li>`;
    }

    // next button - disabled if on last page
    html += `
    <li class="page-item ${page === totalPages ? 'disabled' : ''}">
        <a class="page-link" href="#" onclick="goToPage(${page + 1}); return false;">
            Next
        </a>
    </li>`;

    pagination.innerHTML = html;
}

// navigate to specific page and re-fetch items
function goToPage(page) {
    currentPage = page;
    fetchItems();
}

// event listeners to all search and filter inputs once DOM is ready
document.addEventListener('DOMContentLoaded', () => {

    const inputs = document.querySelectorAll(
        'input[name="search"], select[name="category"], select[name="size"], select[name="condition"], select[name="sort"]'
    );

    inputs.forEach(input => {
        const eventType = input.tagName === 'SELECT' ? 'change' : 'input'; // use change for select dropdowns and input for text fields
        input.addEventListener(eventType, () => {

            currentPage = 1; // reset page to 1 on filter change

            clearTimeout(debounceTimer);

            debounceTimer = setTimeout(() => {
                fetchItems();
            }, 300); // debounce fetch call by 300ms to avoid firing on every keystroke
        });
    });

});
</script>

</body>
</html>
