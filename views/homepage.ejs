<!DOCTYPE html>
<html>

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Charity Shop</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles.css">
</head>

<body class="container mt-4">

    <!-- HERO -->
<div class="container mt-2 mb-4 bg-dark rounded-3 text-white position-relative">
    <div class="p-5 bg-dark text-white rounded-3 text-center">
      <div class="position-absolute top-0 start-0 p-3 d-flex flex-column align-items-start gap-1">
          <span class="badge bg-light text-dark px-3 py-2 fs-6">
             Logged in as: <%= user.username %> (<%= user.role %>)
          </span>
          <a href="/logout" class="btn btn-outline-light mt-2">Logout</a>
      </div>

        <h1 class="display-5 fw-bold">Making a Difference</h1>
        <p class="lead">Donations that are changing lives</p>

        <a href="/items" class="btn btn-light mt-2 me-2">Browse Items</a>

        <% if (user && user.role === 'donor') { %>
            <a href="/items/new" class="btn btn-outline-light mt-2 me-2">Donate Item</a>
        <% } %>

    <% if (user && user.role === 'sys_admin') { %>
        <a href="/admin/dashboard" class="btn btn-outline-light mt-2 me-2">
            Admin Dashboard
        </a>
    <% } %>

    <% if (user && user.role === 'donor') { %>
        <a href="/items/my" class="btn btn-outline-light mt-2 me-2">
            My Listings
        </a>
    <% } %>

     <a href="/requests/my" class="btn btn-outline-light mt-2 me-2">
            My Requests
        </a>

    <% if (user && user.role === 'charity_admin') { %>
        <a href="/admin/charitydashboard" class="btn btn-outline-light mt-2" me-2>
            Charity Dashboard
        </a>
    <% } %>

    </div>
</div>

<div class="container mt-4">


    <!-- RECENTLY DELIVERED -->
    <div class="container mb-5">

        <h3 class="mb-3">Recently Delivered</h3>
        <p class="text-muted">Items successfully received by those in need</p>

        <div id="deliveredCarousel" class="carousel slide" data-bs-ride="carousel">

            <div class="carousel-inner">
                <% for (let i = 0; i < deliveredItems.length; i += 3) { %>
                    <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                        <div class="row justify-content-center g-3">
                            <% deliveredItems.slice(i, i + 3).forEach(item => { %>
                                <div class="col-md-4">
                                    <div class="card shadow-sm">
                                        <img src="/uploads/<%= item.filename || 'placeholder.jpg' %>"
                                            class="card-img-top card-img-cover">
                                        <div class="card-body text-center">
                                            <h6><%= item.title %></h6>
                                            <span class="badge bg-success">Delivered ✔</span>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                <% } %>
            </div>

    <!-- Controls -->
            <button class="carousel-control-prev" type="button" data-bs-target="#deliveredCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>

            <button class="carousel-control-next" type="button" data-bs-target="#deliveredCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>

        </div>

    </div>

        <!-- HOW IT WORKS -->
    <div class="container mb-5 text-center">
        <h3 class="mb-4">How It Works</h3>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="p-4 border rounded-3 h-100">
                    <div class="fs-1 mb-2">👕</div>
                    <h5>1. Donate</h5>
                    <p class="text-muted">Upload clothing items you no longer need</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 border rounded-3 h-100">
                    <div class="fs-1 mb-2">🤝</div>
                    <h5>2. Match</h5>
                    <p class="text-muted">Charities allocate items to recipients</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 border rounded-3 h-100">
                    <div class="fs-1 mb-2">📦</div>
                    <h5>3. Deliver</h5>
                    <p class="text-muted">Items reach those who need them most</p>
                </div>
            </div>
        </div>
    </div>

    <!-- IMPACT -->
    <div class="container mb-5 text-center bg-dark text-white rounded-3 p-5">
        <h3 class="mb-4">Our Impact</h3>
        <div class="row">
            <div class="col-md-4">
                <h2 class="fw-bold">100+</h2>
                <p>Items Donated</p>
            </div>
            <div class="col-md-4">
                <h2 class="fw-bold">75+</h2>
                <p>Recipients Helped</p>
            </div>
            <div class="col-md-4">
                <h2 class="fw-bold">5+</h2>
                <p>Partner Charities</p>
            </div>
        </div>
    </div>


    <div class="container mb-5">

        <h3 class="mb-3">Available Items</h3>

        <div class="row">

            <% featuredItems.forEach(item => { %>

                <div class="col-lg-3 col-md-4 col-sm-6 mb-4">

                    <a href="/items/<%= item.item_id %>" class="text-decoration-none text-dark">

                        <div class="card h-100 shadow-sm">

                            <img src="/uploads/<%= item.filename || 'placeholder.jpg' %>" class="card-img-top">


                            <div class="card-body">
                                <h6><%= item.title %></h6>
                                <p class="small text-muted">
                                    <%= item.description || 'No description' %>
                                </p>
                            </div>

                        </div>

                    </a>

                </div>

            <% }) %>

        </div>

    </div>

</div>

</body>

</html>