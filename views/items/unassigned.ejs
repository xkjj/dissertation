<!DOCTYPE html>
<html>
<head>
    <title>My Clothing Listings</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-4">

<div class="container mt-2 mb-4 bg-dark rounded-3 text-white position-relative">
    <div class="p-5 bg-dark text-white rounded-3 text-center">
      <div class="position-absolute top-0 start-0 p-3 d-flex flex-column align-items-start gap-1">
          <span class="badge bg-light text-dark px-3 py-2 fs-6">
             Logged in as: <%= user.username %> (<%= user.role %>)
          </span>
          <a href="/logout" class="btn btn-outline-light mt-2">Logout</a>
      </div>

        <h1 class="display-5 fw-bold">Unassigned Clothing Listings</h1>
        <p class="lead">Clothing items that need to be assigned to a charity</p>

        <a href="/items/my" class="btn btn-light mt-2 me-2">Back</a>

    </div>
</div>

<% if (items.length === 0) { %>
    <p>You do not have any unassigned listings</p>
<% } %>

<% items.forEach(item => { %>
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title"><%= item.title %></h5>

            <p class="card-text"><%= item.description %></p>

            <p class="text-muted">
                Category: <%= item.category %> |
                Size: <%= item.size || 'N/A' %> |
                Condition: <%= item.condition_desc %> |
                Assigned Charity: <%= item.charity_name ? item.charity_name : 'Not assigned' %>
            </p>

            <p>Status: <strong><%= item.status %></strong></p>

            <a href="/items/<%= item.item_id %>/edit" class="btn btn-sm btn-secondary">Edit</a>

            <form action="/items/<%= item.item_id %>/delete" method="POST" style="display:inline;">
                <button class="btn btn-sm btn-danger"
                        onclick="return confirm('Are you sure you want to delete this item?');">
                    Delete
                </button>
            </form>
        </div>
    </div>
<% }) %>

</body>
</html>


</body>
</html>
