<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Donate Clothing</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>

<body>

<div class="container mt-2 py-4 mb-4 bg-dark rounded-3 text-white">
    <div class="p-4">
        <h2 class="fw-bolder display-5">Donate Clothing</h2>
        <p class="lead">List unwanted clothing items for redistribution</p>
    </div>
</div>

<div class="container">

    <form action="/items" method="POST" enctype="multipart/form-data">

        <div class="mb-3">
            <label class="form-label">Item Title</label>
            <input type="text" name="title" class="form-control" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea name="description" class="form-control"></textarea>
        </div>

        <div class="row mb-3">
            <div class="col">
                <label class="form-label">Category</label>
                <select name="category" class="form-select" required>
                    <option>Men</option>
                    <option>Women</option>
                    <option>Children</option>
                    <option>Unisex</option>
                </select>
            </div>

            <div class="col">
                <label class="form-label">Size</label>
                <select name="size" class="form-select" required>
                    <option>XS</option>
                    <option>S</option>
                    <option>M</option>
                    <option>L</option>
                    <option>XL</option>
                    <option>XXL</option>
                </select>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Condition</label>
            <select name="condition_desc" class="form-select" required>
                <option>New</option>
                <option>Good</option>
                <option>Worn</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Assign to Charity</label>
            <select name="charity_id" class="form-select">
                <option value="">No Charity Assigned</option>
                <% charities.forEach(charity => { %>
                    <option value="<%= charity.charity_id %>">
                        <%= charity.charity_name %>
                    </option>
                <% }) %>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Item Image</label>
            <input type="file" name="images" class="form-control" multiple onchange="previewImage(event)">

            <div id="previewContainer" class="d-flex flex-wrap mt-2"></div>
            <small id="imageCount" class="text-muted"></small>

            <!-- Preview image -->
            <img id="preview" style="max-width:150px; margin-top:10px; display:none;">
        </div>

        <button class="btn btn-dark">Submit Listing</button>
        <a href="/items/my" class="btn btn-outline-dark ms-2">Cancel</a>

    </form>
</div>

<script>
function previewImages(event) {
    const files = event.target.files;
    const container = document.getElementById('previewContainer');

    container.innerHTML = ''; // clear previous previews

    Array.from(files).forEach(file => {
        const img = document.createElement('img');
        img.src = URL.createObjectURL(file);
        img.style.width = '100px';
        img.style.height = '100px';
        img.style.objectFit = 'cover';
        img.classList.add('me-2', 'mb-2', 'rounded');

        container.appendChild(img);
    });
}
</script>
</body>
</html>
