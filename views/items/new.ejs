<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Donate Clothing</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="container mt-4">

<div class="container mt-2 mb-4 bg-dark rounded-3 text-white position-relative">
    <div class="p-5 bg-dark text-white rounded-3 text-center">
      <div class="position-absolute top-0 start-0 p-3 d-flex flex-column align-items-start gap-1">
          <span class="badge bg-light text-dark px-3 py-2 fs-6">
             Logged in as: <%= user.username %> (<%= user.role %>)
          </span>
          <a href="/logout" class="btn btn-outline-light mt-2">Logout</a>
      </div>

        <h1 class="display-5 fw-bold">Donate Clothing</h1>
        <p class="lead">List unwanted clothing items for redistribution</p>

        <a href="/homepage" class="btn btn-light mt-2 me-2">Homepage</a>
        <a href="/items/my" class="btn btn-light mt-2 me-2">Back</a>
    </div>
</div>

<div class="container mt-4" style="max-width: 800px;">

    <div class="card shadow-sm p-4">

        <form id="donateForm" action="/items" method="POST" enctype="multipart/form-data" novalidate>

            <div class="mb-3">
                <label class="form-label fw-semibold">Item Title</label>
                <input type="text" name="title" class="form-control"
                       placeholder="Enter item title"
                       minlength="2" maxlength="100"
                       required>
                <div class="invalid-feedback">Please enter a title (2–100 characters)</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <textarea name="description" class="form-control" rows="3"
                          placeholder="Describe the item"
                          minlength="5" maxlength="500"
                          required></textarea>
                <div class="invalid-feedback">Please enter a description (5–500 characters)</div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Category</label>
                    <select name="category" class="form-select" required>
                        <option value="">Select category</option>
                        <option>Men</option>
                        <option>Women</option>
                        <option>Children</option>
                        <option>Unisex</option>
                    </select>
                    <div class="invalid-feedback">Please select a category</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Size</label>
                    <select name="size" class="form-select" required>
                        <option value="">Select size</option>
                        <option>XS</option>
                        <option>S</option>
                        <option>M</option>
                        <option>L</option>
                        <option>XL</option>
                        <option>XXL</option>
                    </select>
                    <div class="invalid-feedback">Please select a size</div>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Condition</label>
                <select name="condition_desc" class="form-select" required>
                    <option value="">Select condition</option>
                    <option>New</option>
                    <option>Good</option>
                    <option>Worn</option>
                </select>
                <div class="invalid-feedback">Please select a condition</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Assign to Charity</label>
                <select name="charity_id" class="form-select">
                    <option value="">No Charity Assigned</option>
                    <% charities.forEach(charity => { %>
                        <option value="<%= charity.charity_id %>">
                            <%= charity.charity_name %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Item Images</label>
                <input type="file" id="imageInput" name="images"
                       class="form-control" multiple accept="image/*">
                <small class="text-muted">Optional — max 5 images</small>
                <div id="previewContainer" class="d-flex flex-wrap gap-2 mt-3"></div>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4">
                <a href="/items/my" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-dark px-4">Submit Listing</button>
            </div>

        </form>

    </div>

</div>

<script>
// array to track selected image files before form submission
let selectedFiles = [];

// listen for new file selections from image imput
document.getElementById("imageInput").addEventListener("change", function (event) {
    const newFiles = Array.from(event.target.files);

    // enforce 5 image maximum - reject neww selection if exceeded
    if (selectedFiles.length + newFiles.length > 5) {
        alert(`Maximum 5 images allowed.`);
        event.target.value = '';
        return;
    }

    // add new files to array
    selectedFiles = selectedFiles.concat(newFiles);

    // re-render image previews to reflect updated selection
    renderPreviews();
});

// render thumbnail previews for selected images
// called whenever selectedFiles array changes
function renderPreviews() {
    const container = document.getElementById("previewContainer");
    container.innerHTML = ""; // clear existing previews before re-rendering

    selectedFiles.forEach((file, index) => {

        // create wrapper div to position the remove button above the image
        const wrapper = document.createElement("div");
        wrapper.style.position = "relative";

        // create image preview thumbnail from selected file
        const img = document.createElement("img");
        img.src = URL.createObjectURL(file);
        img.style.width = "100px";
        img.style.height = "100px";
        img.style.objectFit = "cover";
        img.classList.add("rounded", "border");

        // create remove button to sit on top right of thumbnail
        const removeBtn = document.createElement("button");
        removeBtn.innerHTML = "×";
        removeBtn.type = "button";
        removeBtn.className = "btn btn-danger btn-sm";
        removeBtn.style.position = "absolute";
        removeBtn.style.top = "-8px";
        removeBtn.style.right = "-8px";
        removeBtn.style.borderRadius = "50%";
        removeBtn.style.width = "24px";
        removeBtn.style.height = "24px";
        removeBtn.style.padding = "0";
        removeBtn.style.lineHeight = "1";

        // remove image from selectedFiles array and re-render previews when clicked
        removeBtn.onclick = () => {
            selectedFiles.splice(index, 1);
            renderPreviews();
        };

        wrapper.appendChild(img);
        wrapper.appendChild(removeBtn);
        container.appendChild(wrapper);
    });
}

// before submit, sync selectedFiles array back to file input - file input cannot be directly manipulated
document.querySelector("form").addEventListener("submit", function (e) {
    const dataTransfer = new DataTransfer(); // dataTransfer object used to reconstruct file list from selectedFiles

    selectedFiles.forEach(file => {
        dataTransfer.items.add(file);
    });

    document.getElementById("imageInput").files = dataTransfer.files;
});

// bootstrap validation triggered on submit
// prevents submission if any required field fails HTML5 validation constraints
// adds was-validated class to show inline validations
(() => {
    const form = document.getElementById('donateForm');

    form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
        }
        form.classList.add('was-validated');
    }, false);
})();
</script>
</body>
</html>
