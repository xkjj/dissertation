<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Donate Clothing</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>

<body>

<div class="container mt-2 py-4 mb-4 bg-dark rounded-3 text-white">
    <div class="p-4">
        <h2 class="fw-bolder display-5">Assigned Clothing Items</h2>
        <p class="lead">Items awaiting charity approval</p>
        <a href="/admin/charitydashboard" class="btn btn-dark mt-3">Back</a>
    </div>
</div>

<div class="container">

    <% if (items.length === 0) { %>
        <p>No items awaiting approval.</p>
    <% } %>

    <div class="row">

    <% items.forEach(item => { %>

        <div class="col-md-4 mb-4">

            <div class="card h-100">
                <div class="card-body">

                    <h5><%= item.title %></h5>

                    <p><%= item.description %></p>

                    <p class="text-muted">
                        Category: <%= item.category %><br>
                        Size: <%= item.size %><br>
                        Condition: <%= item.condition_desc %>
                    </p>

                    <p>
                        Donor: <strong><%= item.donor %></strong>
                    </p>

                    <div class="mt-3">

                        <% if (item.status === 'assigned') { %>

                            <form action="/admin/charity-items/<%= item.item_id %>/approve" method="POST" class="d-inline">
                                <button class="btn btn-success btn-sm">Accept</button>
                            </form>

                            <form action="/admin/charity-items/<%= item.item_id %>/reject" method="POST" class="d-inline">
                                <button class="btn btn-danger btn-sm">Reject</button>
                            </form>

                            <% } %>
                    </div>
                </div>
            </div>
        </div>
    <% }) %>
    </div>
</div>

</body>
</html>
