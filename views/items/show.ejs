<!DOCTYPE html>
<html>
<head>
    <title><%= item.title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="container mt-4">


<div class="container mt-2 pb-4 mb-4 bg-dark rounded-3 text-white position-relative">
    <div class="p-5 bg-dark text-white rounded-3 text-center">
         <div class="position-absolute top-0 start-0 p-3 d-flex flex-column align-items-start gap-1">
          <span class="badge bg-light text-dark px-3 py-2 fs-6">
             Logged in as: <%= user.username %> (<%= user.role %>)
          </span>
          <a href="/logout" class="btn btn-outline-light mt-2">Logout</a>
      </div>
        <h2 class="fw-bolder display-5">Available Clothing</h2>
        <p class="lead">Browse donated clothing items</p>
         <a href="/items" class="btn btn-outline-light mt-3">Back</a>
    </div>
</div>

<div class="row">

    <!-- IMAGE SECTION -->
    <div class="col-md-6">

        <% if (item.images && item.images.length > 0) { %>

            <div id="carouselItem" class="carousel slide">

                <div class="carousel-inner">
                    <% item.images.forEach((img, index) => { %>
                        <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                            <img src="/uploads/<%= img %>" class="d-block w-100 rounded">
                        </div>
                    <% }) %>
                </div>

                <button class="carousel-control-prev" data-bs-target="#carouselItem" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>

                <button class="carousel-control-next" data-bs-target="#carouselItem" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>

            </div>

        <% } else { %>

            <img src="/uploads/placeholder.jpg" class="img-fluid rounded">

        <% } %>

    </div>

    <!-- DETAILS SECTION -->
    <div class="col-md-6">

        <h2><%= item.title %></h2>

        <p class="text-muted"><%= item.description || 'No description provided' %></p>

        <hr>

        <p><strong>Category:</strong> <%= item.category %></p>
        <p><strong>Size:</strong> <%= item.size %></p>
        <p><strong>Condition:</strong> <%= item.condition_desc %></p>
        <p><strong>Charity:</strong> <%= item.charity_name || 'Not assigned' %></p>

        <p class="text-muted">Donated by: <%= item.username %></p>

        <hr>

        <div class="mt-3">

    <% if (user) { %>

        <% if (item.status !== 'approved') { %>
            <button class="btn btn-secondary" disabled>
                Unavailable
            </button>

        <% } else if (user.user_id === item.user_id) { %>
            <button class="btn btn-info" disabled>
                Your Item
            </button>

        <% } else if (item.request_status === 'approved') { %>
            <button class="btn btn-outline-success" disabled>
                Approved
            </button>

        <% } else if (item.request_status === 'pending') { %>
            <button class="btn btn-outline-warning" disabled>
                Request Pending
            </button>

        <% } else if (item.request_status === 'rejected') { %>
            <button class="btn btn-outline-danger" disabled>
                Rejected
            </button>

        <% } else { %>
            <form action="/requests" method="POST">
                <input type="hidden" name="item_id" value="<%= item.item_id %>">
                <button class="btn btn-dark">
                    Request Item
                </button>
            </form>
        <% } %>

    <% } else { %>
        <p class="text-muted">Login to request this item</p>
    <% } %>

</div>

        <br><br>

        <a href="/items" class="btn btn-outline-dark">Back</a>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>