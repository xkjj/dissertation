<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Create Charity Centre</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="container mt-4">

<div class="container mt-2 mb-4 bg-dark rounded-3 text-white position-relative">
    <div class="p-5 bg-dark text-white rounded-3 text-center">
        <div class="position-absolute top-0 start-0 p-3 d-flex flex-column align-items-start gap-1">
            <span class="badge bg-light text-dark px-3 py-2 fs-6">
                Logged in as: <%= user.username %> (<%= user.role %>)
            </span>
            <a href="/logout" class="btn btn-outline-light mt-2">Logout</a>
        </div>

        <h1 class="display-5 fw-bold">Create Charity Centre</h1>
        <p class="lead">Register a new charity centre</p>

        <a href="/admin/charity-centres" class="btn btn-light mt-2">Back</a>
    </div>
</div>

<div class="container mt-4" style="max-width: 800px;">
    <div class="card shadow-sm p-4">

        <form id="charityForm" action="/admin/charity-centres/new" method="POST" novalidate>

            <div class="mb-3">
                <label class="form-label fw-semibold">Charity Name</label>
                <input type="text" name="charity_name" class="form-control"
                       placeholder="Enter charity name"
                       minlength="2" maxlength="150"
                       required>
                <div class="invalid-feedback">Please enter a charity name</div>
            </div>

            <div class="row mb-3">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Address</label>
                    <input type="text" name="charity_address" class="form-control"
                           placeholder="Enter address"
                           required>
                    <div class="invalid-feedback">Please enter an address</div>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">Postcode</label>
                    <input type="text" name="charity_postcode"
                           id="charityPostcode"
                           class="form-control"
                           placeholder="e.g. BT1 1AA"
                           required>
                    <div class="invalid-feedback" id="postcodeFeedback">Please enter a valid UK postcode</div>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Email</label>
                    <input type="email" name="charity_email" class="form-control"
                           placeholder="Enter email address"
                           required>
                    <div class="invalid-feedback">Please enter a valid email address</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Phone</label>
                    <input type="tel" name="charity_phone" class="form-control"
                           placeholder="Enter phone number"
                           pattern="^(\+44\s?7\d{3}|\(?07\d{3}\)?)\s?\d{3}\s?\d{3}$"
                           required>
                    <div class="invalid-feedback">Please enter a valid UK phone number</div>
                </div>
            </div>

            <!-- BUTTONS -->
            <div class="d-flex justify-content-between align-items-center mt-4">
                <a href="/admin/charity-centres" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-dark px-4">Create Charity Centre</button>
            </div>

        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
// get a reference to postcode input
const charityPostcode = document.getElementById('charityPostcode');

// mark postcode field as require on page load so bootstrap validation treats it as invalid before user interacts
document.addEventListener('DOMContentLoaded', () => {
    charityPostcode.setCustomValidity('required');
});

// live UK postcode format checker - fires as user types
// matches UK postcode regex
charityPostcode.addEventListener('input', () => {
    const value = charityPostcode.value.trim().toUpperCase();
    const postcodeRegex = /^[A-Z]{1,2}\d[A-Z\d]?\s?\d[A-Z]{2}$/;

    if (value.length === 0) {
        charityPostcode.setCustomValidity('required');
        document.getElementById('postcodeFeedback').textContent = 'Please enter a valid UK postcode'; // field is empty — mark as invalid with a required message
    } else if (!postcodeRegex.test(value)) {
        charityPostcode.setCustomValidity('invalid');
        document.getElementById('postcodeFeedback').textContent = 'Please enter a valid UK postcode (e.g. BT1 1AA)'; // field has a value but it does not match the UK postcode format
    } else {
        charityPostcode.setCustomValidity(''); // postcode is valid — clear the custom validity error to allow form submission

    }
});

// bootstrap form validation - triggered on submit
// prevents submission if any required field fails HTML5 validation constraints
// adds was-validated class to show inline validation
(() => {
    const form = document.getElementById('charityForm');
    form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
        }
        form.classList.add('was-validated');
    }, false);
})();
</script>
</body>
</html>