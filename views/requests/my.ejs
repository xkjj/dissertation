<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>My Requests</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="container mt-4">

<div class="container mt-2 mb-4 bg-dark rounded-3 text-white position-relative">
    <div class="p-5 bg-dark text-white rounded-3 text-center">
      <div class="position-absolute top-0 start-0 p-3 d-flex flex-column align-items-start gap-1">
          <span class="badge bg-light text-dark px-3 py-2 fs-6">
             Logged in as: <%= user.username %> (<%= user.role %>)
          </span>
          <a href="/logout" class="btn btn-outline-light mt-2">Logout</a>
      </div>

        <h1 class="display-5 fw-bold">My Clothing Requests</h1>
        <p class="lead">Track the status of items you have requested</p>

        <a href="/homepage" class="btn btn-light mt-2 me-2">Back</a>
    </div>
</div>

<div class="container">

    <% if (requests.length === 0) { %>
        <div class="alert alert-info">
            You have not requested any clothing items yet.
        </div>
    <% } else { %>

        <table class="table table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Item</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <% requests.forEach(request => { %>
                    <tr>
                        <td>
                            <%= request.title %>
                        </td>
                        <td>

                        <% if (request.item_status === 'sent') { %>

                            <span class="badge bg-primary">Sent</span>

                            <div class="mt-2">

                                <form action="/requests/<%= request.request_id %>/delivered"
                                    method="POST"
                                    class="d-inline">

                                    <button class="btn btn-sm btn-primary">
                                        Mark as Delivered
                                    </button>

                                </form>

                                <form action="/requests/<%= request.request_id %>/never-arrived"
                                    method="POST"
                                    class="d-inline ms-2">

                                    <button class="btn btn-sm btn-danger">
                                        Never Arrived
                                    </button>

                                </form>

                            </div>

                        <% } else if (request.item_status === 'delivered') { %>

                            <span class="badge bg-primary">Delivered</span>

                        <% } else if (request.item_status === 'never_arrived') { %>

                            <span class="badge bg-danger">Never Arrived</span>

                        <% } else if (request.status === 'approved') { %>

                            <span class="badge bg-success">Approved</span>

                        <% } else if (request.status === 'pending') { %>

                            <span class="badge bg-warning text-dark">Pending</span>

                        <% } else { %>

                            <span class="badge bg-danger">Rejected</span>

                        <% } %>

                    </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

    <% } %>

</div>

</body>
</html>
