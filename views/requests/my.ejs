<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>My Clothing Requests</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="container mt-4">

    <div class="container mt-2 mb-4 bg-dark rounded-3 text-white position-relative">
        <div class="p-5 bg-dark text-white rounded-3 text-center">
            <div class="position-absolute top-0 start-0 p-3 d-flex flex-column align-items-start gap-1">
                <span class="badge bg-light text-dark px-3 py-2 fs-6">
                    Logged in as: <%= user.username %> (<%= user.role %>)
                </span>
                <a href="/logout" class="btn btn-outline-light mt-2">Logout</a>
            </div>

            <h1 class="display-5 fw-bold">My Clothing Requests</h1>
            <p class="lead">Track the status of items you have requested</p>

            <a href="/homepage" class="btn btn-light mt-2 me-2">Back</a>
        </div>
    </div>

    <div class="container mt-2">

        <% if (requests.length===0) { %>
            <div class="text-center py-5 text-muted">
                <p class="fs-5">You have not requested any clothing items yet.</p>
                <a href="/items" class="btn btn-dark mt-2">Browse Items</a>
            </div>
            <% } else { %>


                <ul class="nav nav-tabs mb-4 w-100" id="requestTabs" style="display: flex;">
                    <li class="nav-item flex-fill text-center">
                        <button class="nav-link w-100 active" onclick="filterRequests('all')">
                            All
                            <span class="badge bg-secondary ms-1">
                                <%= requests.length %>
                            </span>
                        </button>
                    </li>
                    <li class="nav-item flex-fill text-center">
                        <button class="nav-link w-100" onclick="filterRequests('pending')">
                            Pending
                            <span class="badge bg-warning text-dark ms-1">
                                <%= requests.filter(r=> r.status === 'pending').length %>
                            </span>
                        </button>
                    </li>
                    <li class="nav-item flex-fill text-center">
                        <button class="nav-link w-100" onclick="filterRequests('approved')">
                            Approved
                            <span class="badge bg-success ms-1">
                                <%= requests.filter(r => r.status === 'approved' && !['sent','delivered','never_arrived'].includes(r.item_status)).length %>
                            </span>
                        </button>
                    </li>
                    <li class="nav-item flex-fill text-center">
                        <button class="nav-link w-100" onclick="filterRequests('sent')">
                            Sent
                            <span class="badge bg-primary ms-1">
                                <%= requests.filter(r=> r.item_status === 'sent').length %>
                            </span>
                        </button>
                    </li>
                    <li class="nav-item flex-fill text-center">
                        <button class="nav-link w-100" onclick="filterRequests('delivered')">
                            Delivered
                            <span class="badge bg-dark ms-1">
                                <%= requests.filter(r=> r.item_status === 'delivered').length %>
                            </span>
                        </button>
                    </li>
                    <li class="nav-item flex-fill text-center">
                        <button class="nav-link w-100" onclick="filterRequests('rejected')">
                            Rejected
                            <span class="badge bg-danger ms-1">
                                <%= requests.filter(r=> r.status === 'rejected').length %>
                            </span>
                        </button>
                    </li>
                </ul>

                <p class="text-muted small mb-3" id="requestCount">
                    Showing <%= requests.length %> request<%= requests.length !==1 ? 's' : '' %>
                </p>

                <div class="row g-3 mb-5" id="requestsGrid">
                    <% requests.forEach(request=> { %>

                        <%
                            // filter tab this card belongs to based on item and request status
                            const filterStatus =
                                request.item_status === 'sent'          ? 'sent'      :
                                request.item_status === 'delivered'     ? 'delivered' :
                                request.item_status === 'never_arrived' ? 'rejected'  :
                                request.status     === 'approved'       ? 'approved'  :
                                request.status     === 'pending'        ? 'pending'   : 'rejected';

                            // colour of the top border accent on each card
                            const accentColor =
                                filterStatus === 'pending'   ? '#ffc107' :
                                filterStatus === 'approved'  ? '#198754' :
                                filterStatus === 'sent'      ? '#0d6efd' :
                                filterStatus === 'delivered' ? '#212529' : '#dc3545';

                            // boostrap badge call for status label
                            const badgeClass = {
                                pending:   'bg-warning text-dark',
                                approved:  'bg-success',
                                sent:      'bg-primary',
                                delivered: 'bg-dark',
                                rejected:  'bg-danger'
                            }[filterStatus] || 'bg-secondary';

                            // human-readable label
                            const badgeLabel =
                                request.item_status === 'sent'          ? 'Sent'          :
                                request.item_status === 'delivered'     ? 'Delivered'     :
                                request.item_status === 'never_arrived' ? 'Never Arrived' :
                                request.status      === 'approved'      ? 'Approved'      :
                                request.status      === 'pending'       ? 'Pending'       : 'Rejected';
                             %>

                            <div class="col-xl-3 col-lg-4 col-md-6 request-card" data-status="<%= filterStatus %>">
                                <div class="card h-100 shadow-sm">

                                    <img src="/uploads/<%= request.image || 'placeholder.jpg' %>" class="card-img-top">

                                    <div class="card-body d-flex flex-column">

                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <h6 class="fw-bold mb-0">
                                                <%= request.title %>
                                            </h6>
                                            <span class="badge <%= badgeClass %> ms-2">
                                                <%= badgeLabel %>
                                            </span>
                                        </div>

                                        <p class="text-muted small mb-2">
                                            <strong>Category:</strong>
                                            <%= request.category %><br>
                                                <strong>Size:</strong>
                                                <%= request.size || 'N/A' %><br>
                                                    <strong>Condition:</strong>
                                                    <%= request.condition_desc %>
                                        </p>

                                        <% if (request.item_status==='sent' ) { %>
                                            <div class="mt-auto d-flex gap-2">
                                                <form action="/requests/<%= request.request_id %>/delivered"
                                                    method="POST" class="w-50">
                                                    <button class="btn btn-success btn-sm w-100">✓ Received</button>
                                                </form>
                                                <form action="/requests/<%= request.request_id %>/never-arrived"
                                                    method="POST" class="w-50">
                                                    <button class="btn btn-outline-danger btn-sm w-100">✕ Not
                                                        Arrived</button>
                                                </form>
                                            </div>
                                            <% } else if (request.item_status==='delivered' ) { %>
                                                <p class="text-success small mb-0 mt-auto">✓ Confirmed received</p>
                                                <% } else if (request.item_status==='never_arrived' ) { %>
                                                    <p class="text-danger small mb-0 mt-auto">✕ Reported as not arrived
                                                    </p>
                                                    <% } else if (request.status==='approved' ) { %>
                                                        <p class="text-muted small mb-0 mt-auto">⏳ Being prepared for
                                                            dispatch</p>
                                                        <% } else if (request.status==='pending' ) { %>
                                                            <p class="text-muted small mb-0 mt-auto">⏳ Awaiting charity
                                                                review</p>
                                                            <% } else { %>
                                                                <p class="text-muted small mb-0 mt-auto">✕ Request not
                                                                    approved</p>
                                                                <% } %>

                                    </div>
                                </div>
                            </div>

                            <% }) %>
                </div>

                <% } %>
    </div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
        // filter request cards by status when a tab is clicked
        function filterRequests(status) {

            // update the active tab - remove active from all tabs first
            // then re-apply to tab that matches selected status
            document.querySelectorAll('#requestTabs .nav-link').forEach(btn => {
                btn.classList.remove('active');
                if (btn.getAttribute('onclick') === `filterRequests('${status}')`) {
                    btn.classList.add('active');
                }
            });

            // show/hide each request card based on whether its data-status attribute
            // matches selected filter - show all cards if all is selected
            let visible = 0;
            document.querySelectorAll('.request-card').forEach(card => {
                const match = status === 'all' || card.dataset.status === status;
                card.style.display = match ? '' : 'none';
                if (match) visible++;
            });

            // update count text below tabs to reflect amount of cards currently displayed
            document.getElementById('requestCount').textContent =
                `Showing ${visible} request${visible !== 1 ? 's' : ''}`;
        }
</script>

</body>

</html>