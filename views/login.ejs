<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="./styles.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body class="container mt-4">

<div class="container mt-2 mb-4 bg-dark rounded-3 text-white position-relative">
    <div class="p-5 bg-dark text-white rounded-3 text-center">
        <h1 class="display-5 fw-bold">Welcome back</h1>
        <p class="lead">Login here</p>
    </div>
</div>

    <div class="container" style="max-width: 450px;">

        <div class="card shadow-sm p-4">

        
          <% if (error) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <strong>Login failed:</strong> <%= error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
          <% } %>

            <form action="/" method="POST">

                <div class="mb-3">
                    <label class="form-label fw-semibold">Username</label>
                    <input type="text"
                           class="form-control"
                           name="username_field"
                           placeholder="Enter username"
                           required>
                </div>

                <div class="mb-4">
                      <label class="form-label fw-semibold">Password</label>

                      <div class="input-group">
                          <input type="password"
                                class="form-control"
                                id="passwordInput"
                                name="password_field"
                                placeholder="Enter password"
                                required>

                          <button class="btn btn-outline-secondary" type="button" id="togglePassword">
                              <i class="bi bi-eye"></i>
                          </button>
                      </div>
                      <small id="capsWarning" class="text-danger" style="display: none;">
                          Caps Lock is ON
                      </small>
                  </div>

                <button class="btn btn-dark w-100 mb-3" type="submit">
                    Login
                </button>

                <div class="text-center">
                    <small>
                        Don’t have an account?
                        <a href="/createaccount">Create one</a>
                    </small>
                </div>

            </form>

        </div>

    </div>

<script>
const passwordInput = document.getElementById("passwordInput"); // reference for password input field
const toggleBtn = document.getElementById("togglePassword"); // reference for toggle password visibility button
const capsWarning = document.getElementById("capsWarning"); // reference for caps lock warning

// toggle password field visibility when show/hide button is clicked
// switches input type between password (hidden) and text (visible)
toggleBtn.addEventListener("click", () => {
    const isPassword = passwordInput.type === "password";

    passwordInput.type = isPassword ? "text" : "password";
    toggleBtn.innerHTML = isPassword 
    ? '<i class="bi bi-eye-slash"></i>' // slashed eye icon when password is visible
    : '<i class="bi bi-eye"></i>'; // eye icon when password is hidden
});

// caps lock detection when user releases a key
// shows/hides caps lock warning message accordingly
passwordInput.addEventListener("keyup", (event) => {
    if (event.getModifierState("CapsLock")) {
        capsWarning.style.display = "block";
    } else {
        capsWarning.style.display = "none";
    }
});

// check caps lock state on keydown to catch case where user presses Caps lock itself - would not trigger keyup detection alone
passwordInput.addEventListener("keydown", (event) => {
    if (event.getModifierState("CapsLock")) {
        capsWarning.style.display = "block";
    } else {
        capsWarning.style.display = "none";
    }
});

</script>

</body>

</html>